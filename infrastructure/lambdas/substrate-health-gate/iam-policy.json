{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SsmDiskProbe",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:GetCommandInvocation"
      ],
      "Resource": [
        "arn:aws:ssm:us-east-1::document/AWS-RunShellScript",
        "arn:aws:ec2:us-east-1:711398986525:instance/i-09b539c844515d549",
        "arn:aws:ec2:us-east-1:711398986525:instance/i-018eb3307a21329bf",
        "arn:aws:ssm:us-east-1:711398986525:*"
      ]
    },
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:711398986525:log-group:/aws/lambda/alpha-engine-substrate-health-gate*"
    }
  ]
}
