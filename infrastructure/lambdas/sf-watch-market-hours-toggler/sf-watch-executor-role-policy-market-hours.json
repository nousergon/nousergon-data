{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DiagnoseFleetSF",
      "Effect": "Allow",
      "Action": [
        "states:DescribeExecution",
        "states:GetExecutionHistory",
        "states:ListExecutions",
        "states:DescribeStateMachine"
      ],
      "Resource": [
        "arn:aws:states:us-east-1:711398986525:stateMachine:ne-weekly-freshness-pipeline",
        "arn:aws:states:us-east-1:711398986525:execution:ne-weekly-freshness-pipeline:*",
        "arn:aws:states:us-east-1:711398986525:stateMachine:ne-preopen-trading-pipeline",
        "arn:aws:states:us-east-1:711398986525:execution:ne-preopen-trading-pipeline:*",
        "arn:aws:states:us-east-1:711398986525:stateMachine:ne-postclose-trading-pipeline",
        "arn:aws:states:us-east-1:711398986525:execution:ne-postclose-trading-pipeline:*",
        "arn:aws:states:us-east-1:711398986525:stateMachine:alpha-engine-eod-pipeline",
        "arn:aws:states:us-east-1:711398986525:execution:alpha-engine-eod-pipeline:*"
      ]
    },
    {
      "Sid": "RerunFleetSFFromFailedStep",
      "Effect": "Allow",
      "Action": ["states:StartExecution"],
      "Resource": [
        "arn:aws:states:us-east-1:711398986525:stateMachine:ne-weekly-freshness-pipeline",
        "arn:aws:states:us-east-1:711398986525:stateMachine:alpha-engine-eod-pipeline"
      ]
    },
    {
      "Sid": "DiagnoseLogs",
      "Effect": "Allow",
      "Action": [
        "logs:GetLogEvents",
        "logs:FilterLogEvents",
        "logs:DescribeLogStreams",
        "logs:DescribeLogGroups",
        "logs:StartQuery",
        "logs:StopQuery",
        "logs:GetQueryResults"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:711398986525:log-group:/aws/*alpha-engine*:*"
      ]
    },
    {
      "Sid": "DiagnoseMetrics",
      "Effect": "Allow",
      "Action": ["cloudwatch:GetMetricData", "cloudwatch:GetMetricStatistics"],
      "Resource": "*"
    },
    {
      "Sid": "ReadArtifactsForDiagnosis",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::alpha-engine-research",
        "arn:aws:s3:::alpha-engine-research/*"
      ]
    },
    {
      "Sid": "EnrichWatchLog",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::alpha-engine-research/consolidated/*_sf_watch/*"
    },
    {
      "Sid": "WriteSfWatchUsageTelemetry",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::alpha-engine-research/claude_code_usage/watch/*"
    },
    {
      "Sid": "ReadWriteSfWatchCompletionMarkers",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::alpha-engine-research/sf_watch/_control/*"
    },
    {
      "Sid": "ReadFleetPatAndClaudeTokenAndTelegramCreds",
      "Effect": "Allow",
      "Action": "ssm:GetParameter",
      "Resource": [
        "arn:aws:ssm:us-east-1:711398986525:parameter/alpha-engine/saturday_sf_watch/github_pat",
        "arn:aws:ssm:us-east-1:711398986525:parameter/alpha-engine/groom/claude_code_oauth_token",
        "arn:aws:ssm:us-east-1:711398986525:parameter/alpha-engine/TELEGRAM_BOT_TOKEN",
        "arn:aws:ssm:us-east-1:711398986525:parameter/alpha-engine/TELEGRAM_CHAT_ID",
        "arn:aws:ssm:us-east-1:711398986525:parameter/alpha-engine/saturday_sf_watch/autonomous_merge_enabled"
      ]
    },
    {
      "Sid": "RerunHelperMutexSteal",
      "Effect": "Allow",
      "Action": ["dynamodb:GetItem", "dynamodb:DeleteItem"],
      "Resource": "arn:aws:dynamodb:us-east-1:711398986525:table/alpha-engine-sf-execution-mutex"
    }
  ]
}
