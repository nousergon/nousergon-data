{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeDataSpotDispatcherLambda",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:us-east-1:711398986525:function:alpha-engine-data-spot-dispatcher"
    },
    {
      "Sid": "PollDataSpotSsmCommand",
      "Effect": "Allow",
      "Action": "ssm:GetCommandInvocation",
      "Resource": "*"
    },
    {
      "Sid": "AlertOnFailure",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "arn:aws:sns:us-east-1:711398986525:alpha-engine-alerts"
    }
  ]
}
