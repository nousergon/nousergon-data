{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alpha Engine Signals",
  "description": "Research output consumed by predictor, executor, and backtester. Written weekly by Research to signals/{date}/signals.json and signals/latest.json.",
  "type": "object",
  "required": ["date", "market_regime", "universe"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Run date (YYYY-MM-DD)"
    },
    "run_time": {
      "type": "string",
      "description": "Time of run (HH:MM:SS)"
    },
    "architecture_version": {
      "type": "string",
      "description": "Research architecture version"
    },
    "market_regime": {
      "type": "string",
      "enum": ["bull", "neutral", "bear"],
      "description": "Current market regime assessment. 3-class Ang-Bekaert taxonomy (v0.42.0 / 2026-05-28). Legacy 4-class 'caution' retired per caution-regime-retirement-260528.md — its driving signals (VIX, HY OAS, SPY 30d return) are weighted continuously into regime_intensity_z (predictor META_FEATURE 13) rather than discretized into a 4th category. Portfolio-protective hysteresis is a separate axis on the predictor drawdown leg (risk_on/caution/risk_off). Historical signals.json artifacts with 'caution' in market_regime are grandfathered — consumers tolerant of legacy enum on read."
    },
    "sector_ratings": {
      "type": "object",
      "description": "Per-sector ratings with modifier and outlook"
    },
    "sector_modifiers": {
      "type": "object",
      "description": "Per-sector score modifiers (0.7-1.3)"
    },
    "universe": {
      "type": "array",
      "description": "Full population of tracked stocks",
      "items": {
        "$ref": "#/$defs/signal_entry"
      }
    },
    "buy_candidates": {
      "type": "array",
      "description": "Stocks promoted to buy consideration",
      "items": {
        "$ref": "#/$defs/signal_entry"
      }
    },
    "population": {
      "type": "array",
      "description": "Current population roster"
    },
    "signals": {
      "type": "object",
      "description": "Legacy signals format (deprecated)"
    }
  },
  "$defs": {
    "signal_entry": {
      "type": "object",
      "required": ["ticker", "signal", "score"],
      "properties": {
        "ticker": {
          "type": "string",
          "description": "Stock ticker symbol"
        },
        "signal": {
          "type": "string",
          "enum": ["ENTER", "EXIT", "REDUCE", "HOLD"],
          "description": "Trading signal"
        },
        "score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Composite attractiveness score (0-100)"
        },
        "rating": {
          "type": "string",
          "enum": ["BUY", "HOLD", "SELL"],
          "description": "Long-term rating"
        },
        "conviction": {
          "type": "string",
          "enum": ["rising", "stable", "declining"],
          "description": "Score trend direction"
        },
        "sector": {
          "type": "string",
          "description": "GICS sector"
        },
        "sector_rating": {
          "type": "string",
          "enum": ["overweight", "market_weight", "underweight"],
          "description": "Sector-level rating"
        },
        "price_target_upside": {
          "type": ["number", "null"],
          "description": "Estimated upside to price target (decimal, e.g. 0.18 = 18%)"
        },
        "thesis_summary": {
          "type": "string",
          "description": "One-paragraph investment thesis"
        },
        "sub_scores": {
          "type": "object",
          "properties": {
            "quant": { "type": ["number", "null"] },
            "qual": { "type": ["number", "null"] }
          },
          "description": "Quantitative and qualitative sub-scores"
        }
      }
    }
  }
}
